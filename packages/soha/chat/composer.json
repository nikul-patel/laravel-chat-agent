{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "soha/chat",
    "description": "Livewire + Flux chat widget for Laravel",
    "version": "0.1.0",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/database": "^12.0",
        "illuminate/http": "^12.0",
        "illuminate/json-schema": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/support": "^12.0",
        "illuminate/translation": "^12.0",
        "illuminate/validation": "^12.0",
        "illuminate/view": "^12.0",
        "laravel/mcp": "^0.2.1",
        "livewire/flux": "^2.4",
        "livewire/livewire": "^3.6",
        "openai-php/laravel": "^0.16.0"
    },
    "autoload": {
        "psr-4": {
            "Soha\\Chat\\": "src/",
            "Soha\\Chat\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Soha\\Chat\\SohaChatServiceProvider"
            ]
        }
    }
}
